---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden px-4 pt-16 pb-20 sm:px-6 lg:px-8">
      <div class="pointer-events-none absolute inset-0 opacity-[0.03]"
        style="background-image: linear-gradient(var(--color-terminal-green) 1px, transparent 1px), linear-gradient(90deg, var(--color-terminal-green) 1px, transparent 1px); background-size: 40px 40px;">
      </div>

      <div class="relative mx-auto max-w-4xl text-center">
        <div class="mb-6 inline-block rounded-lg border border-terminal-border bg-terminal-surface px-4 py-2 font-[family-name:var(--font-mono)] text-sm text-terminal-dim">
          <span class="text-terminal-green">$</span> operad boot
        </div>

        <h1 class="mb-4 font-[family-name:var(--font-mono)] text-4xl font-bold tracking-tight text-terminal-bright sm:text-5xl">
          operad<span class="text-terminal-green">.</span>stream
        </h1>

        <p class="mx-auto mb-2 max-w-2xl text-xl text-terminal-text sm:text-2xl">
          Manage all your Claude Code sessions from one dashboard
        </p>

        <p class="mb-4 max-w-2xl mx-auto text-sm text-terminal-dim">
          Web UI for skills, memories, and prompt history across every project.
          Auto-boots all saved projects on startup. Health checks, memory monitoring, and crash recovery keep everything running.
        </p>

        <div class="mb-8 flex flex-wrap items-center justify-center gap-2 font-[family-name:var(--font-mono)] text-xs">
          {["Android/Termux", "Linux", "macOS"].map((p) => (
            <span class="rounded border border-terminal-green/30 bg-terminal-green/5 px-2.5 py-1 text-terminal-green">{p}</span>
          ))}
        </div>

        <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href="https://github.com/tribixbite/operad"
            class="inline-flex items-center gap-2 rounded-lg border border-terminal-green bg-terminal-green/10 px-6 py-3 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-green transition-colors hover:bg-terminal-green/20"
            target="_blank" rel="noopener">
            GitHub
          </a>
          <a href="https://www.npmjs.com/package/operadic"
            class="inline-flex items-center gap-2 rounded-lg border border-terminal-border px-6 py-3 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-text transition-colors hover:border-terminal-dim hover:text-terminal-bright"
            target="_blank" rel="noopener">
            npm: operadic
          </a>
          <a href="#cli"
            class="inline-flex items-center gap-2 rounded-lg border border-terminal-border px-6 py-3 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-text transition-colors hover:border-terminal-dim hover:text-terminal-bright">
            CLI Reference
          </a>
        </div>

        <nav class="mt-8 flex flex-wrap justify-center gap-2">
          {[
            { href: "#install", label: "Install" },
            { href: "#dashboard", label: "Dashboard" },
            { href: "#cli", label: "CLI" },
            { href: "#platforms", label: "Platforms" },
            { href: "#configuration", label: "Configuration" },
            { href: "#architecture", label: "Architecture" },
            { href: "#rest-api", label: "REST API" },
            { href: "#lifecycle", label: "Lifecycle" },
            { href: "#resilience", label: "Resilience" },
          ].map(({ href, label }) => (
            <a href={href}
              class="rounded border border-terminal-border/50 px-3 py-1 font-[family-name:var(--font-mono)] text-xs text-terminal-dim transition-colors hover:border-terminal-green hover:text-terminal-green">
              {label}
            </a>
          ))}
        </nav>
      </div>
    </section>

    <!-- Key Features -->
    <section class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <div class="grid gap-6 sm:grid-cols-3">
          <div class="rounded-lg border border-terminal-green/20 bg-terminal-surface p-5">
            <div class="mb-3 font-[family-name:var(--font-mono)] text-lg text-terminal-green">01</div>
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-bold text-terminal-bright">Unified dashboard</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim leading-relaxed">
              Browse and manage skills, memories, and CLAUDE.md files across all your repos from one web interface.
              Start, stop, restart any session with a click.
            </p>
          </div>
          <div class="rounded-lg border border-terminal-amber/20 bg-terminal-surface p-5">
            <div class="mb-3 font-[family-name:var(--font-mono)] text-lg text-terminal-amber">02</div>
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-bold text-terminal-bright">Prompt history + search</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim leading-relaxed">
              Full conversation history across every project with search, starring, and token usage tracking.
              Never lose a useful prompt or solution again.
            </p>
          </div>
          <div class="rounded-lg border border-terminal-cyan/20 bg-terminal-surface p-5">
            <div class="mb-3 font-[family-name:var(--font-mono)] text-lg text-terminal-cyan">03</div>
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-bold text-terminal-bright">Auto-boot on startup</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim leading-relaxed">
              All saved projects start automatically in dependency order.
              Health checks, auto-restart, and memory pressure management keep them running 24/7.
            </p>
          </div>
        </div>

        <div class="mt-6 grid gap-6 sm:grid-cols-3">
          <div class="rounded-lg border border-terminal-green/20 bg-terminal-surface p-5">
            <div class="mb-3 font-[family-name:var(--font-mono)] text-lg text-terminal-green">04</div>
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-bold text-terminal-bright">Agentic AI</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim leading-relaxed">
              OODA cognitive loop with 4 specialized agents: master controller, optimizer, preference learner, and ideator.
              Goal trees, decision journals, strategy versioning, and cross-agent knowledge sharing.
            </p>
          </div>
          <div class="rounded-lg border border-terminal-amber/20 bg-terminal-surface p-5">
            <div class="mb-3 font-[family-name:var(--font-mono)] text-lg text-terminal-amber">05</div>
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-bold text-terminal-bright">Token Quota</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim leading-relaxed">
              Weekly token tracking with velocity trends, daily breakdowns, and per-session usage attribution.
              Configurable warning and critical thresholds with automated optimizer responses.
            </p>
          </div>
          <div class="rounded-lg border border-terminal-cyan/20 bg-terminal-surface p-5">
            <div class="mb-3 font-[family-name:var(--font-mono)] text-lg text-terminal-cyan">06</div>
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-bold text-terminal-bright">Tool System</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim leading-relaxed">
              Extensible tool registry with autonomy levels from observe to autonomous.
              Trust calibration, tool leases, persistent scheduling (cron/interval), and TOML-based custom tools.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Install -->
    <section id="install" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-8 font-[family-name:var(--font-mono)] text-2xl font-bold text-terminal-bright sm:text-3xl">
          <span class="text-terminal-green">#</span> Install
        </h2>

        <div class="overflow-hidden rounded-lg border border-terminal-border bg-terminal-surface">
          <div class="border-b border-terminal-border px-4 py-2 text-xs text-terminal-dim">quick start</div>
          <div class="p-4 font-[family-name:var(--font-mono)] text-sm leading-relaxed">
            <div><span class="text-terminal-dim">$</span> <span class="text-terminal-bright">npm i -g operadic</span></div>
            <div class="mt-3 text-terminal-dim"># create config</div>
            <div><span class="text-terminal-dim">$</span> <span class="text-terminal-bright">mkdir -p ~/.config/operad</span></div>
            <div><span class="text-terminal-dim">$</span> <span class="text-terminal-bright">operad config --init</span></div>
            <div class="mt-3 text-terminal-dim"># boot everything</div>
            <div><span class="text-terminal-dim">$</span> <span class="text-terminal-bright">operad boot</span></div>
          </div>
        </div>

        <p class="mt-4 font-[family-name:var(--font-mono)] text-xs text-terminal-dim">
          Or from source:
          <code class="text-terminal-text">git clone https://github.com/tribixbite/operad && cd operad && bun install && bun run build</code>
        </p>
      </div>
    </section>

    <!-- Architecture -->
    <section id="architecture" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-8 font-[family-name:var(--font-mono)] text-2xl font-bold text-terminal-bright sm:text-3xl">
          <span class="text-terminal-green">#</span> Architecture
        </h2>

        <div class="overflow-x-auto rounded-lg border border-terminal-border bg-terminal-surface p-6">
          <pre class="font-[family-name:var(--font-mono)] text-xs leading-relaxed sm:text-sm"><code><span class="text-terminal-dim">┌─────────────────────────────────────────────────────────┐</span>
<span class="text-terminal-dim">│</span>  <span class="text-terminal-bright">operad.toml</span>  ──>  <span class="text-terminal-green">operad daemon</span> <span class="text-terminal-dim">(:18970)</span>                <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>                       │                                  <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>             ┌─────────┼─────────┐                         <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>             ▼         ▼         ▼                         <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>         <span class="text-terminal-cyan">Session</span>   <span class="text-terminal-cyan">Session</span>   <span class="text-terminal-cyan">Session</span>                     <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>         <span class="text-terminal-dim">(claude)</span>  <span class="text-terminal-dim">(daemon)</span>  <span class="text-terminal-dim">(service)</span>                    <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>             │         │         │                         <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>             └─────────┼─────────┘                         <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>                       ▼                                  <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>                 <span class="text-terminal-amber">tmux server</span>                              <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>                       │                                  <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>             ┌─────────┼─────────┐                         <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>             ▼         ▼         ▼                         <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>       <span class="text-terminal-bright">Health</span>    <span class="text-terminal-bright">Memory</span>    <span class="text-terminal-bright">Dashboard</span>                  <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">│</span>       <span class="text-terminal-dim">checks</span>    <span class="text-terminal-dim">monitor</span>   <span class="text-terminal-dim">SSE + REST</span>                 <span class="text-terminal-dim">│</span>
<span class="text-terminal-dim">└─────────────────────────────────────────────────────────┘</span></code></pre>
        </div>

        <div class="mt-6 grid gap-4 sm:grid-cols-3">
          <div class="rounded-lg border border-terminal-border/50 bg-terminal-surface/50 p-4">
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-green">Session Types</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim">
              <code>claude</code> — polls readiness, sends "go"<br>
              <code>daemon</code> — custom command with env<br>
              <code>service</code> — headless background process
            </p>
          </div>
          <div class="rounded-lg border border-terminal-border/50 bg-terminal-surface/50 p-4">
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-amber">Health Checks</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim">
              tmux_alive, http, process, custom.<br>
              Configurable thresholds + auto-restart.
            </p>
          </div>
          <div class="rounded-lg border border-terminal-border/50 bg-terminal-surface/50 p-4">
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-cyan">Memory Pressure</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim">
              Real-time memory monitoring.<br>
              Levels: normal &rarr; warning &rarr; critical &rarr; emergency.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Platforms -->
    <section id="platforms" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-8 font-[family-name:var(--font-mono)] text-2xl font-bold text-terminal-bright sm:text-3xl">
          <span class="text-terminal-green">#</span> Platform Support
        </h2>

        <div class="grid gap-4 sm:grid-cols-3">
          <div class="rounded-lg border border-terminal-green/30 bg-terminal-green/5 p-4">
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-green">Android / Termux</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim leading-relaxed">
              Termux notifications + battery<br>
              ADB phantom process fix<br>
              Wake lock (termux-wake-lock)<br>
              Tab creation via am intents<br>
              Process budget tracking
            </p>
          </div>
          <div class="rounded-lg border border-terminal-cyan/30 bg-terminal-cyan/5 p-4">
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-cyan">Linux</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim leading-relaxed">
              notify-send notifications<br>
              /sys battery via power_supply<br>
              systemd-inhibit wake lock<br>
              /proc process monitoring<br>
              XDG path conventions
            </p>
          </div>
          <div class="rounded-lg border border-terminal-amber/30 bg-terminal-amber/5 p-4">
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-amber">macOS</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim leading-relaxed">
              osascript notifications<br>
              pmset battery monitoring<br>
              caffeinate wake lock<br>
              ps/lsof process inspection<br>
              Terminal.app tab support
            </p>
          </div>
        </div>

        <div class="mt-6 overflow-hidden rounded-lg border border-terminal-border bg-terminal-surface">
          <div class="border-b border-terminal-border px-4 py-2 text-xs text-terminal-dim">platform detection at runtime</div>
          <div class="p-4 font-[family-name:var(--font-mono)] text-xs leading-relaxed sm:text-sm">
            <div><span class="text-terminal-cyan">TERMUX_VERSION</span> <span class="text-terminal-dim">set?</span> <span class="text-terminal-dim">&rarr;</span> <span class="text-terminal-green">android</span></div>
            <div><span class="text-terminal-cyan">process.platform</span> <span class="text-terminal-dim">===</span> <span class="text-terminal-amber">"darwin"</span> <span class="text-terminal-dim">&rarr;</span> <span class="text-terminal-amber">darwin</span></div>
            <div><span class="text-terminal-dim">else &rarr;</span> <span class="text-terminal-cyan">linux</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Configuration -->
    <section id="configuration" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-8 font-[family-name:var(--font-mono)] text-2xl font-bold text-terminal-bright sm:text-3xl">
          <span class="text-terminal-green">#</span> Configuration
        </h2>

        <p class="mb-4 text-sm text-terminal-dim">
          Config lives at <code class="text-terminal-green">~/.config/operad/operad.toml</code>.
          Supports <code class="text-terminal-amber">$ENV_VAR</code> expansion and schema validation.
        </p>

        <div class="overflow-hidden rounded-lg border border-terminal-border bg-terminal-surface">
          <div class="border-b border-terminal-border px-4 py-2 text-xs text-terminal-dim">~/.config/operad/operad.toml</div>
          <div class="p-4 font-[family-name:var(--font-mono)] text-xs leading-relaxed sm:text-sm">
            <div><span class="text-terminal-bright">[operad]</span></div>
            <div><span class="text-terminal-cyan">dashboard_port</span> = <span class="text-terminal-amber">18970</span></div>
            <div><span class="text-terminal-cyan">health_interval_s</span> = <span class="text-terminal-amber">120</span></div>
            <div><span class="text-terminal-cyan">wake_lock_policy</span> = <span class="text-terminal-green">"active_sessions"</span></div>
            <div class="mt-3 text-terminal-dim"># Claude Code session</div>
            <div><span class="text-terminal-bright">[[session]]</span></div>
            <div><span class="text-terminal-cyan">name</span> = <span class="text-terminal-green">"my-project"</span></div>
            <div><span class="text-terminal-cyan">type</span> = <span class="text-terminal-green">"claude"</span></div>
            <div><span class="text-terminal-cyan">path</span> = <span class="text-terminal-green">"$HOME/git/my-project"</span></div>
            <div class="mt-3 text-terminal-dim"># Daemon with custom command</div>
            <div><span class="text-terminal-bright">[[session]]</span></div>
            <div><span class="text-terminal-cyan">name</span> = <span class="text-terminal-green">"api"</span></div>
            <div><span class="text-terminal-cyan">type</span> = <span class="text-terminal-green">"service"</span></div>
            <div><span class="text-terminal-cyan">command</span> = <span class="text-terminal-green">"bun run dev"</span></div>
            <div><span class="text-terminal-cyan">depends_on</span> = [<span class="text-terminal-green">"my-project"</span>]</div>
          </div>
        </div>

        <div class="mt-6 overflow-hidden rounded-lg border border-terminal-border bg-terminal-surface">
          <table class="w-full font-[family-name:var(--font-mono)] text-xs sm:text-sm">
            <thead>
              <tr class="border-b border-terminal-border">
                <th class="px-4 py-3 text-left text-terminal-green">Field</th>
                <th class="px-4 py-3 text-left text-terminal-dim">Type</th>
                <th class="px-4 py-3 text-left text-terminal-dim">Description</th>
              </tr>
            </thead>
            <tbody>
              {[
                { name: "name", type: "string", desc: "Unique session identifier (becomes tmux session name)" },
                { name: "type", type: "enum", desc: "claude | daemon | service" },
                { name: "path", type: "string?", desc: "Working directory ($ENV expansion supported)" },
                { name: "command", type: "string?", desc: "Command to run (daemon/service types)" },
                { name: "depends_on", type: "string[]", desc: "Sessions that must start first" },
                { name: "priority", type: "number?", desc: "Boot order priority (lower = earlier)" },
                { name: "health", type: "object?", desc: "Health check config (check, url, threshold)" },
                { name: "auto_go", type: "bool?", desc: "Auto-send 'go' to Claude sessions on ready" },
              ].map((v, i) => (
                <tr class={i < 7 ? "border-b border-terminal-border/30" : ""}>
                  <td class="px-4 py-2.5 text-terminal-bright">{v.name}</td>
                  <td class="px-4 py-2.5 text-terminal-amber">{v.type}</td>
                  <td class="px-4 py-2.5 text-terminal-dim">{v.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- CLI -->
    <section id="cli" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-8 font-[family-name:var(--font-mono)] text-2xl font-bold text-terminal-bright sm:text-3xl">
          <span class="text-terminal-green">#</span> CLI
        </h2>

        <div class="overflow-hidden rounded-lg border border-terminal-border bg-terminal-surface">
          <div class="p-4 font-[family-name:var(--font-mono)] text-sm leading-relaxed">
            <div class="text-terminal-dim">~ $<span class="text-terminal-bright"> operad boot</span></div>
            <div class="mt-1 text-terminal-dim">  <span class="text-terminal-green">&#10003;</span> wake lock acquired</div>
            <div class="text-terminal-dim">  <span class="text-terminal-green">&#10003;</span> my-project started (claude)</div>
            <div class="text-terminal-dim">  <span class="text-terminal-green">&#10003;</span> api started (service)</div>
            <div class="mt-3 text-terminal-dim">~ $<span class="text-terminal-bright"> operad status</span></div>
            <div class="mt-1 text-terminal-green">  operad daemon uptime 4h 23m</div>
            <div class="text-terminal-dim">  NAME          STATUS    RSS     UPTIME    HEALTH</div>
            <div class="text-terminal-dim">  my-project    <span class="text-terminal-green">running</span>   245MB   4h 23m    <span class="text-terminal-green">ok</span></div>
            <div class="text-terminal-dim">  api           <span class="text-terminal-green">running</span>   38MB    4h 22m    <span class="text-terminal-green">ok</span></div>
          </div>
        </div>

        <div class="mt-6 space-y-3">
          {[
            { cmd: "operad boot", desc: "Start daemon + all sessions in dependency order" },
            { cmd: "operad status", desc: "Show daemon uptime, memory, battery, and session table" },
            { cmd: "operad health", desc: "Run health checks on all sessions" },
            { cmd: "operad go <name>", desc: "Send \"go\" to a Claude session waiting for input" },
            { cmd: "operad start <name>", desc: "Start a stopped session" },
            { cmd: "operad stop <name>", desc: "Stop a running session" },
            { cmd: "operad restart <name>", desc: "Stop + start a session" },
            { cmd: "operad open <path>", desc: "Open a new Claude session dynamically" },
            { cmd: "operad close <name>", desc: "Stop and remove a dynamic session from registry" },
            { cmd: "operad recent", desc: "List recent Claude projects from history" },
            { cmd: "operad tabs", desc: "Open terminal tabs for running sessions" },
            { cmd: "operad memory", desc: "Show system memory and per-session RSS" },
            { cmd: "operad config", desc: "Validate and display parsed config" },
            { cmd: "operad suspend <name>", desc: "Freeze session (SIGSTOP)" },
            { cmd: "operad resume <name>", desc: "Unfreeze session (SIGCONT)" },
            { cmd: "operad upgrade", desc: "Rebuild, restart daemon" },
            { cmd: "operad shutdown", desc: "Gracefully stop daemon (sessions persist)" },
          ].map((c) => (
            <div class="flex items-baseline gap-3 font-[family-name:var(--font-mono)] text-sm">
              <code class="text-terminal-green shrink-0">{c.cmd}</code>
              <span class="text-terminal-dim text-xs">— {c.desc}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dashboard -->
    <section id="dashboard" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-8 font-[family-name:var(--font-mono)] text-2xl font-bold text-terminal-bright sm:text-3xl">
          <span class="text-terminal-green">#</span> Dashboard
        </h2>

        <p class="mb-6 text-sm text-terminal-dim">
          Web dashboard on port <code class="text-terminal-green">18970</code> with real-time SSE updates.
          Manage everything from your browser — sessions, skills, memories, prompt history.
        </p>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-lg border border-terminal-border/50 bg-terminal-surface/50 p-4">
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-green">Sessions</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim">
              Start/stop/restart any session.<br>
              System gauges (memory, battery, ADB).<br>
              Recent projects with search + quick open.
            </p>
          </div>
          <div class="rounded-lg border border-terminal-border/50 bg-terminal-surface/50 p-4">
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-amber">Prompt History</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim">
              Full conversation history across all projects.<br>
              Search by content, project, or date.<br>
              Star and save important prompts. Token tracking.
            </p>
          </div>
          <div class="rounded-lg border border-terminal-border/50 bg-terminal-surface/50 p-4">
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-cyan">Skills &amp; Memories</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim">
              Browse skills and CLAUDE.md across repos.<br>
              View and edit auto-memories per project.<br>
              Unified config management.
            </p>
          </div>
          <div class="rounded-lg border border-terminal-border/50 bg-terminal-surface/50 p-4">
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-bright">Memory Monitor</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim">
              System memory breakdown.<br>
              Per-session RSS usage.<br>
              Process manager (force-stop on Android).
            </p>
          </div>
          <div class="rounded-lg border border-terminal-border/50 bg-terminal-surface/50 p-4">
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-bright">Logs</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim">
              Real-time structured log tail via SSE.<br>
              Filter by level and session.<br>
              Auto-scroll with pause on hover.
            </p>
          </div>
          <div class="rounded-lg border border-terminal-border/50 bg-terminal-surface/50 p-4">
            <h3 class="mb-2 font-[family-name:var(--font-mono)] text-sm font-medium text-terminal-bright">Settings</h3>
            <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim">
              Edit operad config from the browser.<br>
              Manage notification preferences.<br>
              ADB and wake lock controls.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- REST API -->
    <section id="rest-api" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-8 font-[family-name:var(--font-mono)] text-2xl font-bold text-terminal-bright sm:text-3xl">
          <span class="text-terminal-green">#</span> REST API
        </h2>

        <p class="mb-6 text-sm text-terminal-dim">
          All endpoints on <code class="text-terminal-green">http://127.0.0.1:18970</code>.
          SSE endpoint pushes state updates in real time.
        </p>

        <div class="overflow-hidden rounded-lg border border-terminal-border bg-terminal-surface">
          <table class="w-full font-[family-name:var(--font-mono)] text-xs sm:text-sm">
            <thead>
              <tr class="border-b border-terminal-border">
                <th class="px-4 py-3 text-left text-terminal-green">Endpoint</th>
                <th class="px-4 py-3 text-left text-terminal-dim">Method</th>
                <th class="px-4 py-3 text-left text-terminal-dim">Description</th>
              </tr>
            </thead>
            <tbody>
              {[
                { path: "/api/status", method: "GET", desc: "Full daemon state (sessions, memory, battery)" },
                { path: "/api/events", method: "SSE", desc: "Real-time state push" },
                { path: "/api/start/:name", method: "POST", desc: "Start a session" },
                { path: "/api/stop/:name", method: "POST", desc: "Stop a session" },
                { path: "/api/restart/:name", method: "POST", desc: "Stop + start" },
                { path: "/api/go/:name", method: "POST", desc: "Send \"go\" to Claude session" },
                { path: "/api/open/:name", method: "POST", desc: "Register + start dynamic session" },
                { path: "/api/close/:name", method: "POST", desc: "Stop + unregister dynamic session" },
                { path: "/api/recent", method: "GET", desc: "Recent Claude projects" },
                { path: "/api/memory", method: "GET", desc: "System memory + per-session RSS" },
                { path: "/api/processes", method: "GET", desc: "Running processes (Android: app list)" },
                { path: "/api/kill/:pkg", method: "POST", desc: "Force-stop a process" },
              ].map((v, i) => (
                <tr class={i < 11 ? "border-b border-terminal-border/30" : ""}>
                  <td class="px-4 py-2.5 text-terminal-bright">{v.path}</td>
                  <td class={`px-4 py-2.5 ${v.method === "SSE" ? "text-terminal-cyan" : v.method === "POST" ? "text-terminal-amber" : "text-terminal-green"}`}>{v.method}</td>
                  <td class="px-4 py-2.5 text-terminal-dim">{v.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Session Lifecycle -->
    <section id="lifecycle" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-8 font-[family-name:var(--font-mono)] text-2xl font-bold text-terminal-bright sm:text-3xl">
          <span class="text-terminal-green">#</span> Session Lifecycle
        </h2>

        <div class="overflow-x-auto rounded-lg border border-terminal-border bg-terminal-surface p-6">
          <pre class="font-[family-name:var(--font-mono)] text-xs leading-relaxed sm:text-sm"><code><span class="text-terminal-dim">pending</span> <span class="text-terminal-dim">&rarr;</span> <span class="text-terminal-amber">waiting</span> <span class="text-terminal-dim">&rarr;</span> <span class="text-terminal-cyan">starting</span> <span class="text-terminal-dim">&rarr;</span> <span class="text-terminal-green">running</span> <span class="text-terminal-dim">&harr;</span> <span class="text-terminal-amber">degraded</span>
                                            <span class="text-terminal-dim">│</span>
                                            <span class="text-terminal-dim">├&rarr;</span> <span class="text-red-400">failed</span>
                                            <span class="text-terminal-dim">│</span>
                                            <span class="text-terminal-dim">└&rarr;</span> <span class="text-terminal-dim">stopping &rarr; stopped</span></code></pre>
        </div>

        <div class="mt-6 space-y-3">
          {[
            { state: "pending", color: "text-terminal-dim", desc: "Defined in config, not yet processed" },
            { state: "waiting", color: "text-terminal-amber", desc: "Waiting for depends_on sessions" },
            { state: "starting", color: "text-terminal-cyan", desc: "Tmux session created, process launching" },
            { state: "running", color: "text-terminal-green", desc: "Active, health checks passing" },
            { state: "degraded", color: "text-terminal-amber", desc: "Running but health checks failing" },
            { state: "failed", color: "text-red-400", desc: "Exceeded restart limit" },
            { state: "stopped", color: "text-terminal-dim", desc: "Gracefully stopped" },
          ].map((s) => (
            <div class="flex items-baseline gap-3 font-[family-name:var(--font-mono)] text-sm">
              <code class={`shrink-0 ${s.color}`}>{s.state}</code>
              <span class="text-terminal-dim text-xs">— {s.desc}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Crash Resilience -->
    <section id="resilience" class="px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-8 font-[family-name:var(--font-mono)] text-2xl font-bold text-terminal-bright sm:text-3xl">
          <span class="text-terminal-green">#</span> Crash Resilience
        </h2>

        <p class="mb-6 text-sm text-terminal-dim">
          Designed so that <strong class="text-terminal-bright">every running session survives</strong> host app crashes.
          The daemon, watchdog, and tmux server all run as independent processes (PPid: 1).
        </p>

        <div class="grid gap-3 sm:grid-cols-2">
          {[
            { layer: "Wake lock", desc: "Acquired once, never released. Prevents OS from killing background processes." },
            { layer: "Phantom fix", desc: "Android: disables phantom process killer, Doze standby, and app idle." },
            { layer: "Process detach", desc: "Daemon, watchdog, and tmux all run as PPid: 1 — independent of host app." },
            { layer: "Socket self-heal", desc: "IPC socket recreated via HTTP API when tmpfs is cleaned. Recovery in <1s." },
            { layer: "Watchdog loop", desc: "Bash loop restarts daemon after OOM kill. Sessions persist in tmux for re-adoption." },
            { layer: "Trace log", desc: "appendFileSync log survives crashes. Check last line for daemon state before SIGKILL." },
          ].map(({ layer, desc }) => (
            <div class="rounded-lg border border-terminal-border/50 bg-terminal-surface/50 p-3">
              <h4 class="mb-1 font-[family-name:var(--font-mono)] text-xs font-medium text-terminal-green">{layer}</h4>
              <p class="font-[family-name:var(--font-mono)] text-xs text-terminal-dim">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-terminal-border px-4 py-8 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl text-center font-[family-name:var(--font-mono)] text-xs text-terminal-dim">
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="https://github.com/tribixbite/operad" class="transition-colors hover:text-terminal-green" target="_blank" rel="noopener">GitHub</a>
          <span class="text-terminal-border">|</span>
          <a href="https://www.npmjs.com/package/operadic" class="transition-colors hover:text-terminal-green" target="_blank" rel="noopener">npm</a>
          <span class="text-terminal-border">|</span>
          <span>MIT License</span>
        </div>
      </div>
    </footer>
  </main>
</Layout>
