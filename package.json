{
  "name": "operadic",
  "version": "0.4.6",
  "type": "commonjs",
  "description": "operad — manage all your Claude Code sessions from one dashboard. Web UI for skills, memories, and prompt history across projects. Auto-boots saved projects with health checks and crash recovery.",
  "author": "tribixbite",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tribixbite/operad"
  },
  "bin": {
    "operad": "dist/tmx.js"
  },
  "files": [
    "dist/",
    "dashboard/dist/",
    "watchdog.sh",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "claude",
    "tmux",
    "orchestrator",
    "session-manager",
    "claude-code",
    "terminal",
    "cross-platform"
  ],
  "scripts": {
    "build": "node build.cjs",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/fix-android-binaries.mjs || true"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ws": "^8.5.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "@esbuild/android-arm64": "^0.24.0",
    "@anthropic-ai/claude-agent-sdk": "0.2.104"
  },
  "peerDependencies": {
    "claude-chrome-android": "*"
  },
  "peerDependenciesMeta": {
    "claude-chrome-android": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  }
}
